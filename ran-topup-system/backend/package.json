    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mssql": "^12.3.0",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
